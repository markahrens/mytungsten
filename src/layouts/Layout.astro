---
import { Font } from "astro:assets";
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="MyTungsten, the personal web site for Mark Ahrens" />
		<meta name="viewport" content="width=device-width" />
		<meta property="og:title" content="MyTungsten" />
		<meta property="og:type" content="website" />
		<meta property="og:description" content="The personal web site for Mark Ahrens" />
		<meta property="og:image" content="https://www.mytungsten.net/web-app-manifest-512x512.png" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | MyTungsten</title>
		<link rel="alternate" type="application/rss+xml" title="RSS Feed for MyTungsten" href="/feed.xml" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<Font cssVariable="--font-geom" />
		<Font cssVariable="--font-zalando-sans" />
		<slot name="head" />
	</head>
	<!-- Google tag (gtag.js) -->
	<script async src="https://www.googletagmanager.com/gtag/js?id=G-YZ00BVBCXZ"></script>
	<script>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());

		gtag('config', 'G-YZ00BVBCXZ');
	</script>
	<body>
		<nav>
			<a href="/" class="site-logo-container">
				<svg version="1.1" id="mt-logo" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px"
				viewBox="0 0 1024 1024" xml:space="preserve">
				<style>
					.st0 {
						fill:none;
						stroke:#1e293b;
						stroke-width:120;
						stroke-miterlimit:10;
					}
				</style>
					<path class="st0" d="M128.2,642c0-71,57.5-128.5,128.5-128.5S385.2,571.1,385.2,642"/>
					<path class="st0" d="M385.2,642c0-71,57.5-128.5,128.5-128.5S642.2,571.1,642.2,642"/>
					<line class="st0" x1="128.2" y1="640" x2="128.2" y2="840"/>
					<line class="st0" x1="385.2" y1="640" x2="385.2" y2="840"/>
					<path class="st0" d="M899.2,656.6c0,71-57.5,128.5-128.5,128.5s-128.5-57.5-128.5-128.5"/>
					<line class="st0" x1="642.2" y1="189.6" x2="642.2" y2="668.6"/>
					<line class="st0" x1="619.8" y1="374.6" x2="826.8" y2="374.6"/>
				</svg>
				<span>MyTungsten</span>
			</a>
			<ul>
				<li><a href="/blog">Blog</a></li>
				<li><a href="/trips">Trips</a></li>
				<li><a href="/projects">Projects</a></li>
				<li><a href="/flights">Flights</a></li>
				<li><a href="/about">About</a></li>
			</ul>

		</nav>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--lightColor: #F1FAFB;
		--lightColorAlt: #d3e0ea;
		--darkColor: #2b3a6b;
		--darkColorAlt: #3A70B7;
		--bodyLink: #1E88E5;
		
		--color-bg: #f8fafc;
		--color-text: #1e293b;
		--color-metallic: #64748b;
		--color-link: #0369a1;
		--color-border: #cbd5e1;
		--color-white: #ffffff;
	}
	html {
		font-family: var(--font-zalando-sans);
		color: var(--color-text);
	}

	body {
		margin: 0;
		background-color: var(--color-bg);
		font-weight: 400;
	}

	h1, h2, h3 {
		font-family: var(--font-geom);
		padding: 0;
		margin: 0;
	}
	h1 {
		font-weight: 600;
		font-size: 2.4rem;
		padding: 20px 0;
	}
	h2 {
		font-weight: 600;
		font-size: 2rem;
	}
	h3 {
		font-weight: 600;
		font-size: 1.6rem;
	}
	li {
		font-size: 1.2rem;
	}

	p {	
		font-size: 1.2rem;
    line-height: 1.8rem;
	}


	a {
		color: var(--color-link);
		text-decoration: none;
		position: relative;
	}

	a:hover {
		color: var(--darkColorAlt);
	}

	a::before {
		content: "";
		position: absolute;
		display: block;
		width: 100%;
		height: 1.5px;
		bottom: 0;
		left: 0;
		background-color: var(--darkColorAlt);
		transform: scaleX(0);
		transform-origin: top left;
		transition: transform 0.3s ease;
	}

	a:hover::before {
		transform: scaleX(1);
	}

	.content-container {
		max-width: 1136px;
		margin: 0 auto;
		padding: 0 20px;
	}

	.eyebrow {
		font-family: var(--font-geom);
		text-transform: uppercase;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--color-metallic);
		margin: 0 0 8px 0;
	}

	nav {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-geom);
		font-weight: 500;
		padding: 8px;
		border-bottom: 1px solid var(--color-border);
		& a {
			color: var(--color-text);
			text-decoration: none;
		}
		& a:hover {
			color: var(--color-text);
		}
		& a::before {
			background-color: var(--color-text);
		}
		& a.site-logo-container:hover {
			color: var(--color-text);
		}
		& a.site-logo-container::before {
			display: none;
		}
		& .site-logo-container {
			display: flex;
			align-items: center;
			& span {
				display: inline-block;
				padding: 8px 16px;
				font-size: 1.6rem;
			}
		}
		 
		& svg {
			width: 64px;
			display: inline;
		}
		& .st0{
				stroke:var(--color-text)
			
		}
		& ul {
			padding: 0;
			margin: 0;
			display: flex;
			flex-direction: row;
			@media (width <= 600px) { 
				flex-direction: column;
			};
			& li {
				list-style-type: none;
				padding: 16px;
				font-size: 1.1rem;
				text-align: center;
				@media (width <= 600px) { 
					padding: 4px;
				};
			}
		}
	}
	
</style>