---
import { DateTime } from "luxon";
import Layout from "../../layouts/Layout.astro";
import TripMap from '../../components/LeafletTrip.jsx';
import { getAllEvents, slugForEvent, getSportDetails, getConcertDetails } from "../../lib/db";

export async function getStaticPaths() {
  const events = getAllEvents();
  return events.map((e) => ({ params: { slug: slugForEvent(e) } }));
}

const slug = Astro.params.slug as string;
const events = getAllEvents();
const event = events.find((e) => slugForEvent(e) === slug);

if (!event) {
  throw new Error(`Event not found for slug: ${slug}`);
}

const sportDetails = event.category === 'sport' ? getSportDetails(event.id) : undefined;
const concertDetails = event.category === 'concert' ? getConcertDetails(event.id) : undefined;

const eventDate = DateTime.fromISO(event.event_date);
const formattedTime = event.event_time ? DateTime.fromFormat(event.event_time, "HH:mm").toFormat("h:mm a") : undefined;

const categoryIcons: Record<string, string> = {
  sport: '🏟️',
  concert: '🎸',
  theater: '🎭',
  other: '🎟️'
};

const categoryColors: Record<string, string> = {
  sport: '#1e40af', // blue
  concert: '#6b21a8', // purple
  theater: '#b91c1c', // red
  other: '#475569' // slate
};

const brandColor = categoryColors[event.category] || '#475569';
const icon = categoryIcons[event.category] || '🎟️';

let stops = [];
if (event.venue_latitude && event.venue_longitude) {
  stops.push({
    name: event.venue_name || 'Venue',
    abbr: event.venue_city || '',
    lat: event.venue_latitude,
    lng: event.venue_longitude
  });
}
---

<Layout title={`${event.title} - ${eventDate.toFormat("M/d/yyyy")}`}>
  {stops.length > 0 && (
    <link slot="head" rel='stylesheet' href='https://unpkg.com/leaflet@1.8.0/dist/leaflet.css' integrity='sha512-hoalWLoI8r4UszCkZ5kL8vayOGVae1oxXe/2A4AO6J9+580uKHDO3JdHb7NzwwzK5xr/Fs0W40kiNHxM9vyTtQ==' crossorigin='' />
  )}

  <main class="content-container event-detail-page">
    <div class="ticket-pass">
      <div class="ticket-header" style={`background-color: ${brandColor}`}>
        <div class="category-badge">
          <span class="icon">{icon}</span>
          <span class="category-name">{event.category}</span>
        </div>
        <div class="ticket-date">
          {eventDate.toFormat("MMM d, yyyy")}
        </div>
      </div>

      <div class="ticket-body">
        <div class="main-info">
          <h1>{event.title}</h1>
          <div class="venue-location">
            <span class="venue-name">{event.venue_name}</span>
            <span class="venue-city-region">
              {event.venue_city}{event.venue_region ? `, ${event.venue_region}` : ''}{event.venue_country !== 'US' ? `, ${event.venue_country}` : ''}
            </span>
          </div>
        </div>

        <div class="perforation"></div>

        <div class="ticket-stub">
          <div class="stub-content">
            <div class="time-box">
              <span class="eyebrow">Time</span>
              <span class="value">{formattedTime || "N/A"}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="ticket-footer">
        <div class="brand-strip" style={`background-image: repeating-linear-gradient(45deg, ${brandColor} 0, ${brandColor} 10px, var(--color-border) 10px, var(--color-border) 20px)`}></div>
      </div>
    </div>

    <div class="details-grid">
      <!-- Left column: Specific event details and notes -->
      <div class="left-col">
        {sportDetails && (
          <section class="details-section scoreboard-section">
            <h3 class="eyebrow">Game Details</h3>
            <div class="scoreboard-card">
              <div class="league-tag">{sportDetails.league || sportDetails.sport}</div>
              <div class="teams-container">
                <div class="team away-team">
                  <span class="team-name">{sportDetails.away_team}</span>
                  <span class="team-score">{sportDetails.away_score !== null ? sportDetails.away_score : '-'}</span>
                </div>
                <div class="versus">vs</div>
                <div class="team home-team">
                  <span class="team-name">{sportDetails.home_team}</span>
                  <span class="team-score">{sportDetails.home_score !== null ? sportDetails.home_score : '-'}</span>
                </div>
              </div>
              {sportDetails.outcome && (
                <div class={`outcome-badge ${sportDetails.outcome}`}>
                  {sportDetails.outcome === 'win' ? '🏆 Winner' : sportDetails.outcome === 'loss' ? 'Loss' : 'Tie'}
                </div>
              )}
            </div>
          </section>
        )}

        {concertDetails && (
          <section class="details-section concert-section">
            <h3 class="eyebrow">Concert Details</h3>
            <div class="concert-card">
              {concertDetails.tour_name && (
                <div class="detail-row">
                  <span class="label">Tour</span>
                  <span class="value">{concertDetails.tour_name}</span>
                </div>
              )}
              {concertDetails.headliner && (
                <div class="detail-row">
                  <span class="label">Headliner</span>
                  <span class="value">{concertDetails.headliner}</span>
                </div>
              )}
              {concertDetails.openers && (
                <div class="detail-row">
                  <span class="label">Openers</span>
                  <span class="value">{concertDetails.openers}</span>
                </div>
              )}
              {concertDetails.setlist_url && (
                <div class="setlist-link">
                  <a href={concertDetails.setlist_url} target="_blank" rel="noopener noreferrer" class="btn">
                    🎵 View Setlist on setlist.fm
                  </a>
                </div>
              )}
            </div>
          </section>
        )}


      </div>

      <!-- Right column: Venue map and details -->
      <div class="right-col">
        <section class="details-section venue-section">
          <h3 class="eyebrow">Venue Details</h3>
          <div class="venue-card">
            <h4>{event.venue_name}</h4>
            <p class="venue-address">
              {event.venue_city}{event.venue_region ? `, ${event.venue_region}` : ''}{event.venue_country !== 'US' ? `, ${event.venue_country}` : ''}
            </p>
          </div>

          {stops.length > 0 && (
            <div class="map-wrapper clickable-card">
              <TripMap client:only="react" stops={stops} />
            </div>
          )}
        </section>
      </div>
    </div>
  </main>
</Layout>

<style>
  .event-detail-page {
    padding-top: 60px;
    padding-bottom: 120px;
  }

  .ticket-pass {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    margin-bottom: 60px;
    position: relative;
    overflow: hidden;

    .ticket-header {
      padding: 24px 32px;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;

      .category-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        .icon { font-size: 1.4rem; }
        .category-name { font-size: 1.2rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
      }
      .ticket-date { font-family: var(--font-geom); font-size: 1.2rem; font-weight: 600; }
    }

    .ticket-body {
      display: grid;
      grid-template-columns: 1fr auto 280px;
      padding: 40px 32px;
      gap: 32px;

      @media (max-width: 900px) {
        grid-template-columns: 1fr;
        .perforation, .ticket-stub { display: none; }
      }
    }

    .main-info {
      display: flex;
      flex-direction: column;
      gap: 16px;

      h1 {
        font-family: var(--font-geom);
        font-size: 2.8rem;
        line-height: 1.2;
        color: var(--color-text);
      }

      .venue-location {
        display: flex;
        flex-direction: column;
        .venue-name { font-size: 1.2rem; font-weight: 700; color: var(--color-text); }
        .venue-city-region { font-size: 1rem; color: var(--color-metallic); }
      }
    }

    .perforation {
      width: 1px;
      border-left: 2px dashed var(--color-border);
      margin: -40px 0;
    }

    .ticket-stub {
      .stub-content {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .time-box {
        display: flex;
        flex-direction: column;
        .value { font-family: var(--font-geom); font-size: 1.1rem; font-weight: 600; color: var(--color-text); }
      }
    }

    .brand-strip {
      height: 8px;
      opacity: 0.8;
    }
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;

    @media (max-width: 900px) {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .details-section {
    margin-bottom: 40px;
  }

  .scoreboard-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 32px;
    text-align: center;
    position: relative;

    .league-tag {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-metallic);
      margin-bottom: 20px;
    }

    .teams-container {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      margin-bottom: 24px;

      @media (max-width: 600px) {
        flex-direction: column;
        gap: 16px;
        .versus { transform: rotate(90deg); }
      }
    }

    .team {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;

      .team-name {
        font-family: var(--font-geom);
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: 8px;
      }

      .team-score {
        font-family: var(--font-geom);
        font-size: 3rem;
        font-weight: 800;
        color: var(--color-text);
      }
    }

    .versus {
      font-family: var(--font-geom);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--color-metallic);
      text-transform: uppercase;
      background: var(--color-bg-muted);
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--color-border);
    }

    .outcome-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      font-weight: 700;
      text-transform: uppercase;
      font-size: 0.85rem;

      &.win { background: var(--color-success-bg); color: var(--color-success-text); }
      &.loss { background: var(--color-error-bg); color: var(--color-error-text); }
      &.tie { background: var(--color-bg-muted); color: var(--color-metallic); }
    }
  }

  .concert-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;

    .detail-row {
      display: flex;
      justify-content: space-between;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--color-bg-muted);

      &:last-of-type {
        border-bottom: none;
      }

      .label { font-size: 0.9rem; font-weight: 600; color: var(--color-metallic); }
      .value { font-family: var(--font-geom); font-size: 1.1rem; font-weight: 600; color: var(--color-text); }
    }

    .setlist-link {
      margin-top: 8px;
      text-align: center;

      .btn {
        display: inline-block;
        padding: 10px 20px;
        background: var(--color-text);
        color: var(--color-white);
        font-weight: 600;
        transition: background var(--transition-standard);

        &:hover {
          background: var(--color-metallic);
        }

        &::before { display: none; }
      }
    }
  }



  .venue-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 24px;
    margin-bottom: 24px;

    h4 {
      font-family: var(--font-geom);
      font-size: 1.3rem;
      margin-bottom: 8px;
    }

    .venue-address {
      font-size: 1rem;
      color: var(--color-metallic);
      margin-bottom: 16px;
    }

    .map-link {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--color-link);

      &:hover { color: var(--color-text); }
    }
  }

  .map-wrapper {
    height: 350px;
    overflow: hidden;
    position: relative;
    border: 1px solid var(--color-border);
    
    :global(.leaflet-container) {
      height: 100% !important;
      width: 100% !important;
    }
  }
</style>
