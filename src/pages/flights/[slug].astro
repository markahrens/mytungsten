---
import { DateTime, Duration } from "luxon";
import Layout from "../../layouts/Layout.astro";
import FlightCard from "../../components/FlightCard.astro";
import TripMap from '../../components/LeafletTrip.jsx';
import { getAllFlights, slugForFlight, getAirlineInfo, getAirportInfo } from "../../lib/db";

export async function getStaticPaths() {
  const flights = getAllFlights();
  return flights.map((f) => ({ params: { slug: slugForFlight(f) } }));
}

const slug = Astro.params.slug as string;

let flight,
  airline,
  dept_airport,
  arrival_airport,
  dept_difference,
  dept_difference_class,
  arrival_difference,
  arrival_difference_class,
  scheduled_time,
  actual_time,
  status_class = null,
  stops = [];

const all = getAllFlights();
for (const f of all) {
  if (slugForFlight(f) === slug) {
    flight = f;
    break;
  }
}

if (!flight) {
  throw new Error(`Flight not found for slug: ${slug}`);
}

if (flight.airline_code) {
  airline = getAirlineInfo(flight.airline_code);
}

if (flight.dept_airport) {
  dept_airport = getAirportInfo(flight.dept_airport);
  stops.push({name:dept_airport.name, abbr: dept_airport.abbreviation, lat: dept_airport.lat, lng: dept_airport.long})
}

if (flight.arrival_airport) {
  arrival_airport = getAirportInfo(flight.arrival_airport);
  stops.push({name:arrival_airport.name, abbr: arrival_airport.abbreviation, lat: arrival_airport.lat, lng: arrival_airport.long})
}

let dept_gate_scheduled = DateTime.fromISO(flight.dept_gate_scheduled, {
  zone: dept_airport?.timezone,
});

let dept_gate_actual = DateTime.fromISO(flight.dept_gate_actual, {
  zone: dept_airport?.timezone,
});

let arrival_gate_scheduled = DateTime.fromISO(flight.arrival_gate_scheduled, {
  zone: arrival_airport?.timezone,
});

let arrival_gate_actual = DateTime.fromISO(flight.arrival_gate_actual, {
  zone: arrival_airport?.timezone,
});

if (dept_gate_scheduled && dept_gate_actual) {
  dept_difference = dept_gate_actual.diff(dept_gate_scheduled, ["minutes"]);
  dept_difference_class = dept_difference.minutes <= 15 ? "on-time" : "delayed";
}

if (arrival_gate_scheduled && arrival_gate_actual) {
  arrival_difference = arrival_gate_actual.diff(arrival_gate_scheduled , ["minutes"]);
  arrival_difference_class = arrival_difference.minutes <= 15 ? "on-time" : "delayed";
}

if (dept_gate_scheduled && arrival_gate_scheduled) {
  scheduled_time = arrival_gate_scheduled.diff(dept_gate_scheduled, ["hours", "minutes"]);
}

if (dept_gate_actual && arrival_gate_actual) {
  actual_time = arrival_gate_actual.diff(dept_gate_actual, ["hours", "minutes"]);
}
---

<Layout title={`${flight.number} - ${dept_gate_scheduled.toFormat("M/d/yyyy")}`}>
  <link slot="head" rel='stylesheet' href='https://unpkg.com/leaflet@1.8.0/dist/leaflet.css' integrity='sha512-hoalWLoI8r4UszCkZ5kL8vayOGVae1oxXe/2A4AO6J9+580uKHDO3JdHb7NzwwzK5xr/Fs0W40kiNHxM9vyTtQ==' crossorigin='' />
  
  <main class="content-container flight-detail-page">
    <div class="boarding-pass">
      <div class="pass-header" style={`background-color: var(--brandColor1)`}>
        <div class="airline-info">
          <span class="airline-name">{airline.name}</span>
          <span class="flight-number">{flight.number}</span>
        </div>
        <div class="flight-date">
          {dept_gate_scheduled.toFormat("MMM d, yyyy")}
        </div>
      </div>

      <div class="pass-body">
        <div class="route-display">
          <div class="departure">
            <FlightCard
              airport_name={dept_airport.name}
              airport_code={flight.dept_airport}
              scheduled_time={dept_gate_scheduled}
              terminal={flight.dept_terminal}
              gate={flight.dept_gate}
            />
          </div>
          <div class="flight-path">
            <div class="line"></div>
            <div class="plane">✈️</div>
          </div>
          <div class="arrival">
            <FlightCard
              airport_name={arrival_airport.name}
              airport_code={flight.arrival_airport}
              scheduled_time={arrival_gate_scheduled}
              terminal={flight.arrival_terminal}
              gate={flight.arrival_gate}
            />
          </div>
        </div>
        <div class="perforation"></div>
        <div class="stub">
          <div class="stub-content">
            <span class="eyebrow">Status</span>
            <span class={`status-tag ${arrival_difference_class}`}>{flight.status}</span>
            <div class="craft-info">
              <span class="eyebrow">Aircraft</span>
              <span class="value">{flight.craft_type || "N/A"}</span>
              <span class="tail">{flight.tail_number}</span>
            </div>
          </div>
        </div>
      </div>
      
      <div class="pass-footer">
        <div class="brand-strip" style={`background-image: repeating-linear-gradient(45deg, var(--brandColor1) 0, var(--brandColor1) 10px, var(--brandColor2) 10px, var(--brandColor2) 20px, var(--brandColor3) 20px, var(--brandColor3) 30px)`}></div>
      </div>
    </div>

    <div class="details-grid">
      <section class="timing-section">
        <h3 class="eyebrow">Timing Details</h3>
        <div class="timing-cards">
          <div class="timing-card">
            <h4>Scheduled</h4>
            <div class="detail-row">
              <span class="label">Departure</span>
              <span class="value">{dept_gate_scheduled.toFormat("h:mm a")}</span>
            </div>
            <div class="detail-row">
              <span class="label">Arrival</span>
              <span class="value">{arrival_gate_scheduled.toFormat("h:mm a")}</span>
            </div>
            {scheduled_time && (
              <div class="detail-row total">
                <span class="label">Duration</span>
                <span class="value">{scheduled_time.hours}h {scheduled_time.minutes}m</span>
              </div>
            )}
          </div>

          <div class="timing-card">
            <h4>Actual</h4>
            <div class="detail-row">
              <span class="label">Departure</span>
              <span class="value">
                {dept_gate_actual.toFormat("h:mm a")}
                <span class={`offset-tag ${dept_difference_class}`}>{dept_difference.minutes > 0 ? `+${dept_difference.minutes}m` : `${dept_difference.minutes}m`}</span>
              </span>
            </div>
            <div class="detail-row">
              <span class="label">Arrival</span>
              <span class="value">
                {arrival_gate_actual.toFormat("h:mm a")}
                <span class={`offset-tag ${arrival_difference_class}`}>{arrival_difference.minutes > 0 ? `+${arrival_difference.minutes}m` : `${arrival_difference.minutes}m`}</span>
              </span>
            </div>
            {actual_time && (
              <div class="detail-row total">
                <span class="label">Duration</span>
                <span class="value">{actual_time.hours}h {actual_time.minutes}m</span>
              </div>
            )}
          </div>
        </div>
      </section>

      <section class="map-section">
        <h3 class="eyebrow">Flight Path</h3>
        <div class="map-wrapper clickable-card">
          <TripMap client:only="react" stops={stops} />
        </div>
      </section>
    </div>
  </main>
</Layout>

<style
  define:vars={{
    brandColor1: airline?.brand_color1 || '#64748b',
    brandColor2: airline?.brand_color2 || '#94a3b8',
    brandColor3: airline?.brand_color3 || '#cbd5e1',
  }}
>
  .flight-detail-page {
    padding-top: 60px;
    padding-bottom: 120px;
  }

  .boarding-pass {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    margin-bottom: 60px;
    position: relative;
    overflow: hidden;

    .pass-header {
      padding: 24px 32px;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      
      .airline-info {
        display: flex;
        flex-direction: column;
        .airline-name { font-size: 1.2rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
        .flight-number { font-family: var(--font-geom); font-size: 1rem; opacity: 0.9; }
      }
      .flight-date { font-family: var(--font-geom); font-size: 1.2rem; font-weight: 600; }
    }

    .pass-body {
      display: grid;
      grid-template-columns: 1fr auto 240px;
      padding: 40px 32px;
      gap: 32px;
      
      @media (max-width: 1000px) {
        grid-template-columns: 1fr;
        .perforation, .stub { display: none; }
      }
    }

    .route-display {
      display: flex;
      align-items: center;
      gap: 40px;
      
      @media (max-width: 800px) {
        flex-direction: column;
        align-items: flex-start;
        .flight-path { display: none; }
      }
    }

    .flight-path {
      flex: 1;
      position: relative;
      height: 2px;
      background: var(--color-border);
      
      .plane {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(45deg);
        background: var(--color-white);
        padding: 0 12px;
        font-size: 1.5rem;
      }
    }

    .perforation {
      width: 1px;
      border-left: 2px dashed var(--color-border);
      margin: -40px 0;
    }

    .stub {
      .stub-content {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      
      .status-tag {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 4px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.9rem;
        text-align: center;
        
        &.on-time { background: #dcfce7; color: #166534; }
        &.delayed { background: #fee2e2; color: #991b1b; }
      }
      
      .craft-info {
        display: flex;
        flex-direction: column;
        .value { font-family: var(--font-geom); font-size: 1.1rem; font-weight: 600; color: var(--color-text); }
        .tail { font-size: 0.8rem; color: var(--color-metallic); font-weight: 600; }
      }
    }

    .brand-strip {
      height: 8px;
      opacity: 0.8;
    }
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    
    @media (max-width: 900px) {
      grid-template-columns: 1fr;
    }
  }

  .timing-cards {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 24px;
  }

  .timing-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 24px;
    
    h4 {
      font-family: var(--font-geom);
      font-size: 1.2rem;
      margin: 0 0 16px 0;
      color: var(--color-metallic);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .detail-row {
      display: flex;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid var(--color-bg);
      
      .label { font-size: 0.9rem; font-weight: 600; color: var(--color-metallic); }
      .value { 
        font-family: var(--font-geom); 
        font-size: 1.1rem; 
        font-weight: 600; 
        display: flex;
        align-items: center;
        gap: 8px;
      }
      
      &.total {
        border-bottom: none;
        margin-top: 8px;
        padding-top: 16px;
        border-top: 2px solid var(--color-text);
        .value { font-size: 1.4rem; color: var(--color-text); }
      }
    }
  }

  .offset-tag {
    font-size: 0.75rem;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 700;
    &.on-time { background: #dcfce7; color: #166534; }
    &.delayed { background: #fee2e2; color: #991b1b; }
  }

  .map-wrapper {
    margin-top: 24px;
    height: 500px;
    overflow: hidden;
    position: relative;
    border: 1px solid var(--color-border);
    
    :global(.leaflet-container) {
      height: 100% !important;
      width: 100% !important;
    }
  }
</style>
