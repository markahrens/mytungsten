---
import Layout from '../layouts/Layout.astro';
import BlogPost from '../components/PostRow.astro';
import TungstenCard from '../components/TungstenCard.astro';
import { getCollection } from 'astro:content';
const lastestPost = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  ).slice(0,1);
const recentPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  ).slice(1,4);
const dateOptions: object = {
	year: "numeric",
	month: "short",
	day: "numeric",
};
---

<Layout title="Home">
	<main>
		<div class="content-container masthead">
			<h1 class="hero-title">My<span>Tungsten</span></h1>
			<p class="subtitle">The personal website of Mark Ahrens—web technology expert, Drupal specialist, farmer, and soccer fan. Building on the web since 2001.</p>
		</div>

		<div class="bg-container">
			<div class="content-container flex-layout">
				<div class="blog-container">
					<span class="eyebrow">Latest Post</span>
					{lastestPost.map(blogPostEntry => (
						<BlogPost
							href={`/blog/${blogPostEntry.id}`}
							title={blogPostEntry.data.title}
							description={blogPostEntry.data.description}
							date={blogPostEntry.data.date}
						/>
					))}
					<div class="recent-posts">
						<span class="eyebrow">Recent Posts</span>
						{recentPosts.map(blogPostEntry => (
							<div class="recent-posts-post">
								<span class="post-date">{blogPostEntry.data.date.toLocaleDateString('en-US', dateOptions)}</span>
								<a href={`/blog/${blogPostEntry.id}`}>{blogPostEntry.data.title}</a>
							</div>
						))}
					</div>
					
					<p class="view-all"><a href="/blog">View all posts</a></p>
				</div>

				<div class="sidebar-container">
					<TungstenCard />
					<span class="eyebrow">Site Updates</span>
					<ul class="updates-list">
						<li><span>1/1/2024 </span><span>Restored the blog</span></li>
						<li><span>12/24/2023</span><span>Updated site design, restored iPod for Windows review, added more info on About page.</span></li>
						<li><span>2/20/2023</span><span>Restored Euler's Identity page</span></li>
						<li><span>2/14/2023</span><span>Added About page</span></li>
					</ul>
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	.masthead {
		h1 span {
			color: var(--color-metallic);
		}
	}

	.flex-layout {
		@media screen and (min-width: 600px) {
			display: flex;
			gap: 40px;
		}
	}

	.blog-container {
		flex: 1;

		.recent-posts {
			margin-top: 40px;

			.recent-posts-post {
				display: flex;
				gap: 20px;
				padding-bottom: 12px;
				margin-bottom: 12px;
				border-bottom: 1px solid var(--color-border);
				align-items: baseline;

				.post-date {
					flex: 0 0 100px;
					color: var(--color-metallic);
					font-size: 0.8rem;
					font-weight: 600;
				}

				a {
					font-weight: 500;
				}
			}
		}

		.view-all {
			margin-top: 24px;
			font-size: 0.9rem;
		}
	}

	.sidebar-container {
		flex: 0 0 280px;
		padding-left: 40px;
		border-left: 1px solid var(--color-border);

		@media (max-width: 900px) {
			padding-left: 0;
			border-left: none;
			margin-top: 60px;
		}

		.updates-list {
			padding: 0;
			margin: 0;

			li {
				list-style-type: none;
				display: flex;
				flex-direction: column;
				gap: 4px;
				font-size: 0.85rem;
				margin-bottom: 16px;
				line-height: 1.4;

				span:first-child {
					font-weight: 700;
					color: var(--color-metallic);
					font-size: 0.75rem;
				}
			}
		}
	}
</style>
