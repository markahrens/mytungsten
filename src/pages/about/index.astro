---
import Layout from '../../layouts/Layout.astro';
import TungstenCard from '../../components/TungstenCard.astro';
---

<Layout title="About">
	<main>
    <div class="masthead content-container">
      <span class="eyebrow">Biography</span>
      <h1>About Mark Ahrens</h1>
    </div>

    <div class="bg-container">
      <div class="content-container grid-layout">
        <section class="career">
          <h3 class="eyebrow">Professional Career</h3>
          <div class="career-item">
            <h4>Web Team Manager @ UKG</h4>
            <span class="date">Oct 2021 — Present</span>
            <p>Leading the web team in building and supporting enterprise-level Drupal applications.</p>
          </div>
          <div class="career-item">
            <h4>Technical Account Manager @ Acquia</h4>
            <span class="date">2018 — 2021</span>
            <p>Providing technical guidance and support for high-profile Acquia customers.</p>
          </div>
          <div class="career-item">
            <h4>Web Tech Lead @ University of Iowa</h4>
            <span class="date">2006 — 2018</span>
            <p>Over 12 years of experience leading web development initiatives for the university.</p>
          </div>
          <div class="career-theme">
            <p><strong>The Drupal Thread:</strong> Across all these roles, Drupal has been the constant—whether developing, managing, or supporting it.</p>
          </div>
        </section>

        <section class="personal">
          <h3 class="eyebrow">Personal Life</h3>
          <p>Husband to Rebekah and father to Will and Henry. I've spent my life in Illinois and Iowa, currently residing south of the Quad Cities.</p>
          <div class="farm-card clickable-card">
            <h4>Twisted Oaks Farm</h4>
            <p>Our home where we raise sheep and chickens. It’s my bridge between the digital world and the physical earth.</p>
          </div>
          <div class="sports">
            <h3 class="eyebrow">Interests</h3>
            <p>Big fan of soccer and college football. When I'm not in front of a screen or in the pasture, you'll probably find me watching a match.</p>
          </div>
        </section>
      </div>
    </div>

    <div class="content-container">
      <section class="site-history">
        <h3 class="eyebrow">Site History & Evolution</h3>
        <div class="timeline">
          <div class="timeline-item">
            <span class="year">2001</span>
            <p><strong>mytungsten.net</strong> was born. The original home for my web tinkering.</p>
          </div>
          <div class="timeline-item">
            <span class="year">2007</span>
            <p>Moved to <strong>marktopia.net</strong>, a new phase of personal web space.</p>
          </div>
          <div class="timeline-item">
            <span class="year">2013</span>
            <p>Experimented with <strong>markahrens.co</strong>, but it didn't quite stick.</p>
          </div>
          <div class="timeline-item">
            <span class="year">2015+</span>
            <p>The site became a quiet place for tinkering in free time.</p>
          </div>
          <div class="timeline-item highlight">
            <span class="year">Now</span>
            <p>Returning to <strong>mytungsten.net</strong>. Building a permanent archive and home on the web.</p>
          </div>
        </div>
      </section>

      <section class="tungsten-facts">
        <div class="facts-grid">
          <div class="facts-text">
            <h3 class="eyebrow">The Element</h3>
            <p>Tungsten, or Wolfram (W), is the inspiration for this site's name. It's known for its strength and resilience—qualities I admire in both technology and nature.</p>
          </div>
          <TungstenCard />
        </div>
        <p class="specs-link"><a href="/about/original-comp">View Original Computer Specs →</a></p>
      </section>
    </div>
	</main>
</Layout>

<style>
  .masthead {
    display: flex;
    flex-direction: column;
    padding: 120px 20px;
    gap: 20px;

    h1.eyebrow {
      margin-bottom: 0;
    }

    h2 {
      font-size: 3rem;
      max-width: 800px;
      line-height: 1.1;
      font-weight: 600;
    }

    .intro {
      font-size: 1.4rem;
      max-width: 600px;
      color: var(--color-metallic);
      margin-top: 0;
    }
  }

  .bg-container {
		background-color: hsl(from var(--color-bg) h s calc(l - 5));
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
    padding: 80px 0;
  }

  .grid-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 80px;

    @media (width <= 900px) {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .career-item {
    margin-bottom: 30px;
    h4 {
      margin: 0;
      font-size: 1.4rem;
      font-family: var(--font-geom);
    }
    .date {
      font-size: 0.9rem;
      color: var(--color-metallic);
      font-weight: 600;
    }
  }

  .career-theme {
    padding: 20px;
    background: white;
    border-left: 4px solid var(--color-metallic);
    margin-top: 20px;
  }

  .farm-card {
    padding: 24px;
    margin: 20px 0;
    h4 {
      margin: 0 0 10px 0;
      font-family: var(--font-geom);
      font-size: 1.5rem;
    }
  }

  .site-history {
    padding: 100px 0;
    .timeline {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-top: 40px;

      .timeline-item {
        padding: 20px;
        background: white;
        border: 1px solid var(--color-border);
        
        .year {
          font-family: var(--font-geom);
          font-size: 2rem;
          font-weight: 700;
          color: var(--color-metallic);
          display: block;
          margin-bottom: 10px;
        }

        &.highlight {
          border-color: var(--color-text);
          background-color: var(--color-text);
          color: white;
          .year {
            color: var(--color-white);
          }
        }
      }
    }
  }

  .tungsten-facts {
    padding: 0 0 100px 0;
    .facts-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: center;

      @media (width <= 700px) {
        grid-template-columns: 1fr;
      }
    }
    .specs-link {
      margin-top: 40px;
      text-align: center;
      font-size: 1rem;
    }
  }
</style>
