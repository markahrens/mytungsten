---
const { registration, type, flight, seen_date, owner, origin, destination, airline, operator } = Astro.props;
---

<div class="adsb-row-container">
  <div class="adsb-row">
    <!-- Aircraft details (Registration and Type) -->
    <div class="aircraft-col">
      <span class="registration-code">{registration || "Unknown Reg"}</span>
      <span class="type-code">{type || "Unknown Type"}</span>
    </div>
    
    <!-- Route details (Origin -> Destination, and Owner) -->
    <div class="route-col">
      <div class="codes">
        {origin && destination ? (
          <>
            <span class="code">{origin}</span>
            <span class="arrow">→</span>
            <span class="code">{destination}</span>
          </>
        ) : (
          <span class="no-route">No Known Route</span>
        )}
      </div>
      <div class="owner">{owner || "Private Owner"}</div>
    </div>

    <!-- Flight / callsign info -->
    <div class="details-col">
      <div class="flight-number">{flight || "N/A"}</div>
    </div>
  </div>
</div>

<style>
  .adsb-row-container {
    margin-bottom: 12px;
  }

  .adsb-row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: center;
    padding: 16px 24px;
    gap: 24px;
    border: 1px solid var(--color-border);
    background: var(--color-white);
    transition: all 0.2s ease;
  }

  .aircraft-col {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-right: 1px solid var(--color-border);
    padding-right: 24px;
    
    .registration-code {
      font-family: var(--font-geom);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--color-text);
    }
    
    .type-code {
      font-size: 0.85rem;
      font-weight: 400; /* Normal weight, not bold */
      color: var(--color-metallic);
      text-transform: uppercase;
    }
  }

  .route-col {
    .codes {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 4px;
      
      .code {
        font-family: var(--font-geom);
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--color-text);
      }
      
      .no-route {
        font-family: var(--font-geom);
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--color-metallic);
      }
      
      .arrow {
        color: var(--color-metallic);
        font-weight: 400;
        font-size: 1.2rem;
      }
    }
    
    .owner {
      font-size: 0.9rem;
      color: var(--color-metallic);
      font-weight: 500;
    }
  }

  .details-col {
    text-align: right;
    
    .flight-number {
      font-family: var(--font-geom);
      font-weight: 600;
      font-size: 1.4rem;
      color: var(--color-text);
    }
  }

  @media (max-width: 600px) {
    .adsb-row {
      grid-template-columns: 110px 1fr;
      padding: 12px 16px;
      gap: 16px;
    }
    .aircraft-col {
      padding-right: 16px;
      .registration-code { font-size: 1.05rem; }
      .type-code { font-size: 0.75rem; }
    }
    .details-col {
      display: none;
    }
  }
</style>
