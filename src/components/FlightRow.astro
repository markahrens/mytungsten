---
const { href, number, date, dept_airport, arrival_airport, airline, distance} = Astro.props;
const newDate = new Date(date);
// Adjust for UTC/Local mismatch if necessary, but keep it simple
newDate.setUTCHours(12, 0, 0, 0);

import { getAirlineInfo } from "../lib/db";

const dateOptions: object = {
	month: "short",
	day: "numeric",
};

let airline_info = null;
if (airline) {
  airline_info = getAirlineInfo(airline);
}
---

<div class="flight-row-container">
  <a href={href} class="flight-row clickable-card">
    <div class="date-col">
      <span class="month">{newDate.toLocaleDateString('en-US', { month: 'short' })}</span>
      <span class="day">{newDate.getUTCDate()}</span>
    </div>
    
    <div class="route-col">
      <div class="codes">
        <span class="code">{dept_airport}</span>
        <span class="arrow">→</span>
        <span class="code">{arrival_airport}</span>
      </div>
      <div class="airline">{airline_info?.name || airline}</div>
    </div>

    <div class="details-col">
      <div class="number">{number}</div>
      <div class="distance">{distance ? Math.round(distance) + ' mi' : ''}</div>
    </div>
  </a>
</div>

<style>
  .flight-row-container {
    margin-bottom: 12px;
  }

  .flight-row {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: center;
    padding: 16px 24px;
    gap: 24px;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    background: var(--color-white);
    transition: all 0.2s ease;

    &:before {
      display: none;
    }
  }

  .date-col {
    display: flex;
    gap: 6px;
    align-items: baseline;
    border-right: 1px solid var(--color-border);
    padding-right: 24px;
    
    .month, .day {
      font-family: var(--font-geom);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--color-text);
    }
  }

  .route-col {
    .codes {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 4px;
      
      .code {
        font-family: var(--font-geom);
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--color-text);
      }
      
      .arrow {
        color: var(--color-metallic);
        font-weight: 400;
        font-size: 1.2rem;
      }
    }
    
    .airline {
      font-size: 0.9rem;
      color: var(--color-metallic);
      font-weight: 500;
    }
  }

  .details-col {
    text-align: right;
    
    .number {
      font-family: var(--font-geom);
      font-weight: 600;
      font-size: 1.1rem;
      color: var(--color-text);
      margin-bottom: 2px;
    }
    
    .distance {
      font-size: 0.8rem;
      color: var(--color-metallic);
      font-weight: 600;
    }
  }

  @media (max-width: 600px) {
    .flight-row {
      grid-template-columns: 80px 1fr;
      padding: 12px 16px;
      gap: 16px;
    }
    .date-col {
      padding-right: 16px;
      .day { font-size: 1.2rem; }
    }
    .details-col {
      display: none;
    }
  }
</style>