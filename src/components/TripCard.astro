---
import { Image } from "astro:assets";
const { href, title, description, img, alt } = Astro.props;
---

<div class="trip-card clickable-card">
  <div class="image-container">
    <Image src={img} alt={alt} width={600} class="trip-card-image" />
  </div>
  <div class="card-content">
    <h2 class="card-title"><a href={href} class="stretched-link">{title}</a></h2>
    <p class="card-description">{description}</p>
  </div>
</div>

<style>
  .trip-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    height: 100%;
    
    .image-container {
      aspect-ratio: 16 / 10;
      overflow: hidden;
      border-bottom: 1px solid var(--color-border);
    }
    
    .trip-card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    
    &:hover .trip-card-image {
      transform: scale(1.05);
    }
    
    .card-content {
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      flex: 1;
    }
    
    .card-title {
      font-size: 1.4rem;
      font-weight: 700;
      line-height: 1.2;
      color: var(--color-text);
      margin: 0;
      
      a {
        text-decoration: none;
        color: inherit;
      }
    }
    
    .card-description {
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--color-metallic);
      margin: 0;
    }
  }
</style>
