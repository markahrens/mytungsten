{
	"compatibility_date": "2026-05-27",
	"compatibility_flags": ["nodejs_compat"],
	"name": "mytungsten",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "adsb",
      "database_id": "42690e51-8140-44e7-9052-f797f1e9c6f9"
    }
  ]
}